---
import LenisInit from './LenisInit.jsx';
import TopNavBar from './TopNavBar.jsx';
import HeroSection from './HeroSection.jsx';
import Services from './Services.jsx';
import Geography from './Geography.jsx';
import Workflow from './Workflow.jsx';
import Advantages from './Advantages.jsx';
import ProjectsAndMedia from './ProjectsAndMedia.jsx';
import AboutUs from './AboutUs.jsx';
import LogoMarquee from './Marquee.jsx';
import ContactForm from './ContactForm.jsx';
import GeographyMap from './GeographyMap.tsx';
import AI_Chat from './AI_Chat.jsx';
import FAQSection from './Faq.jsx';
import CrmPromo from './CrmPromo.jsx';
import Footer from './Footer.jsx';

const { locale, translations, currentPath } = Astro.props;
---

<LenisInit client:idle />

<div class="flex flex-col min-h-screen bg-white">
  {/* Шапка и фоновое видео */}
  <div class="relative flex flex-col md:min-h-[95vh] min-h-[100%] w-full overflow-hidden bg-slate-900 shadow-xl">
    <img
      src="/video/hero_poster-800.webp"
      srcset="/video/hero_poster-800.webp 800w, /video/hero_poster-1400.webp 1400w"
      sizes="100vw"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover md:hidden"
      width="1400"
      height="900"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <video
      autoplay
      loop
      muted
      playsinline
      preload="none"
      poster="/video/hero_poster-1400.webp"
      class="absolute inset-0 hidden h-full w-full object-cover md:block"
    >
      <source src="/video/hero_video-Second.mp4" media="(min-width: 768px)" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/60"></div>

    <div class="relative z-10 flex flex-col flex-grow w-full">
      <TopNavBar client:visible locale={locale} translations={translations} currentPath={currentPath} />
      <HeroSection client:visible locale={locale} translations={translations} />
    </div>
  </div>

  {/* Главный контент страницы */}
  <main class="py-0 flex flex-col">
    <Services client:idle locale={locale} translations={translations} />
    <Geography client:idle locale={locale} translations={translations} />
    <Workflow client:idle locale={locale} translations={translations} />
    <Advantages client:idle locale={locale} translations={translations} />
    <ProjectsAndMedia client:idle locale={locale} translations={translations} />
    
    <div class="flex flex-col">
      <AboutUs client:idle locale={locale} translations={translations} />
    </div>
    
    <LogoMarquee client:idle locale={locale} translations={translations} />
    <ContactForm client:idle locale={locale} translations={translations} />
    <GeographyMap client:idle locale={locale} translations={translations} />
    <AI_Chat client:idle locale={locale} translations={translations} />
    <FAQSection client:idle locale={locale} translations={translations} />
    <CrmPromo client:idle locale={locale} translations={translations} />
  </main>
  <Footer client:visible locale={locale} translations={translations} />
</div>