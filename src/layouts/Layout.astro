---
import '../styles/global.css';
import SpeedInsights from "@vercel/speed-insights/astro"

const { locale = 'ru', translations = {} } = Astro.props;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{translations.meta?.title ?? 'Landing Page'}</title>
		<meta name="description" content={translations.meta?.description ?? ''} />
		<meta property="og:title" content={translations.meta?.ogTitle ?? ''} />
		<meta property="og:description" content={translations.meta?.ogDescription ?? ''} />
		<meta property="og:url" content={Astro.url.href} />
		<link rel="canonical" href={Astro.url.href} />
	</head>
	<body class="bg-white text-gray-900 min-h-screen antialiased">
		<slot />
		<SpeedInsights/>

		<script>
			import Lenis from "lenis";
			const lenis = new Lenis({
				duration: 1.2,
				easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
				orientation: "vertical",
				gestureOrientation: "vertical",
				smoothWheel: true,
				wheelMultiplier: 1,
				touchMultiplier: 1.5,
				infinite: false,
			});

			function raf(time) {
				lenis.raf(time);
				requestAnimationFrame(raf);
			}

			requestAnimationFrame(raf);
		</script>
	</body>
</html>
