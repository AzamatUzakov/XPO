---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { translations } from '../lib/i18n';

const locale = 'ru';
const t = translations[locale];
const currentPath = Astro.url.pathname;
---

<Layout locale={locale} translations={t} currentPath={currentPath} robots="noindex, nofollow">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4 py-20 bg-slate-950 text-white">
    <h1 class="text-7xl md:text-9xl font-black text-[#00A8CC] tracking-widest drop-shadow-lg animate-pulse">404</h1>
    <h2 class="text-2xl md:text-3xl font-medium mt-4 text-white/90">Страница не найдена / Page not found</h2>
    <p class="text-sm md:text-base mt-2 text-white/60 max-w-md">
      К сожалению, запрашиваемая страница не существует или была перемещена.
    </p>
    <a href="/" class="mt-8 px-8 py-3 md:py-4 bg-[#00A8CC] hover:bg-[#008ba8] text-white font-medium text-sm md:text-base rounded-lg transition-all shadow-lg hover:shadow-cyan-500/20 active:scale-95">
      На главную / Go to Home
    </a>
  </div>
</Layout>
