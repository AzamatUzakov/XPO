---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../lib/i18n';

// Import components
import TopNavBar from '../../components/TopNavBar.jsx';
import HeroSection from '../../components/HeroSection.jsx';
import Services from '../../components/Services.jsx';
import Geography from '../../components/Geography.jsx';
import Workflow from '../../components/Workflow.jsx';
import Advantages from '../../components/Advantages.jsx';
import ProjectsAndMedia from '../../components/ProjectsAndMedia.jsx';
import AboutUs from '../../components/AboutUs.jsx';
import Marquee from '../../components/Marquee.jsx';
import ContactForm from '../../components/ContactForm.jsx';
import GeographyMap from '../../components/GeographyMap.tsx';
import AI_Chat from '../../components/AI_Chat.jsx';
import FAQSection from '../../components/Faq.jsx';
import CrmPromo from '../../components/CrmPromo.jsx';
import Footer from '../../components/Footer.jsx';

const locale = 'en';
const t = translations[locale];
const currentPath = Astro.url.pathname;
---

<Layout locale={locale} translations={t} currentPath={currentPath}>
  <div class="flex flex-col min-h-screen bg-white">
    {/* Шапка и фоновое видео */}
    <div class="relative flex flex-col md:min-h-[95vh] min-h-[100%] w-full overflow-hidden bg-slate-900 shadow-xl">
      <video
        autoplay
        loop
        muted
        playsinline
        preload="none"
        poster="/video/hero_poster.jpg"
        class="absolute inset-0 w-full h-full object-cover"
      >
        <source src="/video/hero_video.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-black/60"></div>

      <div class="relative z-10 flex flex-col flex-grow w-full">
        <TopNavBar client:load locale={locale} translations={t} currentPath={currentPath} />
        <HeroSection client:load locale={locale} translations={t} />
      </div>
    </div>

    {/* Главный контент страницы */}
    <main class="py-0 flex flex-col">
      <Services client:visible />
      <Geography client:visible locale={locale} translations={t} />
      <Workflow client:visible locale={locale} translations={t} />
      <Advantages client:visible />
      <ProjectsAndMedia client:visible />
      
      <div class="flex flex-col">
        <AboutUs client:visible locale={locale} translations={t} />
      </div>
      
      <Marquee client:visible locale={locale} translations={t} />
      <ContactForm client:visible locale={locale} translations={t} />
      <GeographyMap client:visible locale={locale} translations={t} />
      <AI_Chat client:visible locale={locale} translations={t} />
      <FAQSection client:visible />
      <CrmPromo client:visible />
    </main>
    <Footer client:visible locale={locale} translations={t} />
  </div>
</Layout>
